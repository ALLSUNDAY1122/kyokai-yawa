---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { mainCategories, settings, lengthTypes, fearLevels } from "@data/taxonomy";
import { collectionJsonLd } from "@lib/seo";
---

<BaseLayout
  title="検索"
  description="怖い話をタイトル、あらすじ、本文、タグ、舞台、シリーズ名から全文検索できます。"
  jsonLd={collectionJsonLd("検索", "/search/", "怪談ライブラリーの全文検索")}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>
  <Breadcrumbs items={[{ href: "/search/", label: "検索" }]} />
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Search</p>
      <h1>検索</h1>
      <p>タイトル、あらすじ、本文、タグ、舞台、シリーズ名を対象に検索します。検索結果では該当箇所の抜粋を表示します。</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div id="search" class="search-panel" data-pagefind-ui></div>
      <noscript>
        <p class="notice">全文検索にはJavaScriptが必要です。カテゴリ、タグ、シリーズ一覧からも作品を探せます。</p>
      </noscript>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <h2>分類から探す</h2>
      <ul class="chip-list">
        {mainCategories.map((item) => <li><a href={`/categories/${item.slug}/`}>{item.label}</a></li>)}
        {lengthTypes.map((item) => <li><a href={`/stories/?length=${encodeURIComponent(item.label)}`}>{item.label}</a></li>)}
        {fearLevels.map((item) => <li><a href={`/stories/?fear=${item.level}`}>Lv.{item.level}</a></li>)}
        {settings.slice(0, 8).map((item) => <li><a href={`/stories/?setting=${encodeURIComponent(item.label)}`}>{item.label}</a></li>)}
      </ul>
    </div>
  </section>
  <script>
    async function initPagefind() {
      const target = document.querySelector("[data-pagefind-ui]");
      if (!target) return;
      try {
        const pagefind = await import("/pagefind/pagefind-ui.js");
        new pagefind.PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: false,
          excerptLength: 28,
          translations: {
            placeholder: "怪談を検索",
            clear_search: "検索を消す",
            load_more: "さらに表示",
            search_label: "サイト内検索",
            filters_label: "絞り込み",
            zero_results: "該当する作品がありません。",
            many_results: "[COUNT]件の結果",
            one_result: "1件の結果",
            alt_search: "代替検索",
            search_suggestion: "次の語句で検索:",
            searching: "検索中...",
          },
        });
        const query = new URLSearchParams(window.location.search).get("q");
        if (query) {
          const input = target.querySelector("input");
          if (input) {
            input.value = query;
            input.dispatchEvent(new Event("input", { bubbles: true }));
          }
        }
      } catch {
        target.innerHTML = "<p>検索インデックスはビルド後に有効になります。</p>";
      }
    }
    initPagefind();
  </script>
</BaseLayout>
